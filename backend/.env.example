# ========== NAYI FILE: backend/.env.example ==========
# Kyon: Team / deploy par kaunse env vars chahiye — sample (asli password yahan mat likho)
# Copy karke .env banao: cp .env.example .env

PORT=5001
MONGO_URL=mongodb://127.0.0.1:27017/bookStore

# Production (MongoDB Atlas) — apna connection string lagao:
# MONGO_URL=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/bookStore?retryWrites=true&w=majority

# Jab frontend Vercel par ho — CORS ke liye (index.js mein uncomment karo):
# FRONTEND_URL=https://your-app.vercel.app
